# AETHER_01 — Feature Gates Configuration
# Copy this file to .env and adjust as needed.
# All dangerous operations are disabled by default.

# Log level: trace, debug, info, warn, error
RUST_LOG=info

# ── FEATURE GATES ───────────────────────────────────────────
# Set to 1 to enable. Disabled (0) by default.

# Modify Windows boot configuration (bcdedit)
AETHER_BCD_EDIT=0

# Configure HAL and crash dump settings
AETHER_HAL_CONFIG=0

# Mount offline registry hives
AETHER_OFFLINE_REGISTRY=0

# Inject DLLs into running processes
AETHER_DLL_INJECT=0

# Manipulate access tokens (privileges, impersonation)
AETHER_TOKEN_MANIPULATION=0

# Read LSA secrets (Local Security Authority)
AETHER_LSA_SECRETS=0
